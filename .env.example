BOT_TOKEN=123456:replace_me
BOT_USERNAME=your_bot_username
WEBAPP_PUBLIC_URL=https://example.com/app
WEBAPP_ENABLED=true
WEBAPP_LISTEN_HOST=127.0.0.1
WEBAPP_LISTEN_PORT=8080
PRODUCT_DB_PATH=data/nimarita.db
PRODUCT_BACKUP_DIR=data/backups
LOG_LEVEL=INFO
DEFAULT_TIMEZONE=Europe/Moscow
TELEGRAM_INIT_DATA_TTL_SECONDS=3600
APP_SESSION_TTL_SECONDS=7200
APP_SESSION_SECRET=replace_me
PAIR_INVITE_TTL_MINUTES=4320
MINI_APP_SHORT_NAME=
MINI_APP_TITLE=Наше пространство 💖

# Access policy / closed beta feature-flag
ACCESS_ALLOWLIST_ENABLED=false
ALLOWED_USER_IDS=123456789,987654321

# SQLite durability / maintenance
SQLITE_SYNCHRONOUS=FULL
SQLITE_BUSY_TIMEOUT_MS=15000
SQLITE_WAL_AUTOCHECKPOINT_PAGES=1000
SQLITE_JOURNAL_SIZE_LIMIT_BYTES=67108864
SQLITE_CHECKPOINT_MODE=PASSIVE
SQLITE_CHECKPOINT_INTERVAL_SECONDS=300
SQLITE_QUICK_CHECK_ON_STARTUP=true
SQLITE_QUICK_CHECK_INTERVAL_SECONDS=1800
SQLITE_FAIL_FAST_ON_INTEGRITY_ERROR=false
BACKUP_ENABLED=true
BACKUP_ON_STARTUP=true
BACKUP_ON_SHUTDOWN=false
BACKUP_INTERVAL_SECONDS=3600
BACKUP_RETENTION=24
MAINTENANCE_WORKER_POLL_SECONDS=30

REMINDER_WORKER_POLL_SECONDS=5
REMINDER_WORKER_BATCH_SIZE=20
REMINDER_WORKER_CONCURRENCY=4
REMINDER_MAX_RETRIES=4
REMINDER_RETRY_BASE_SECONDS=30
CARE_WORKER_POLL_SECONDS=3
CARE_WORKER_BATCH_SIZE=20
CARE_WORKER_CONCURRENCY=4
CARE_MAX_RETRIES=4
CARE_RETRY_BASE_SECONDS=20
CLEANUP_WORKER_POLL_SECONDS=8
CLEANUP_WORKER_BATCH_SIZE=25
PROCESSING_STALE_SECONDS=180
WORKER_HEARTBEAT_STALE_SECONDS=90
ACTION_MESSAGE_TTL_SECONDS=12
NOTICE_MESSAGE_TTL_SECONDS=20
WELCOME_MESSAGE_TTL_SECONDS=25
CARE_PER_MINUTE_LIMIT=6
CARE_PER_HOUR_LIMIT=40
CARE_DUPLICATE_WINDOW_MINUTES=20
