# Telegram bot
BOT_TOKEN=123456789:replace_with_real_bot_token
LOG_LEVEL=INFO

# Access control
# Comma-separated Telegram user IDs allowed to use bot / Mini App.
ALLOWED_USER_IDS=123456789

# Optional comma-separated chat IDs. Leave empty if user allowlist is enough.
ALLOWED_CHAT_IDS=

# Unified profiles registry lives in profiles.json.
# Copy profiles.example.json to profiles.json and replace IDs / labels.

# Reminder limits
MAX_REMINDER_TEXT_LENGTH=1000
MAX_ACTIVE_REMINDERS_PER_CHAT=100
SCHEDULER_MISFIRE_GRACE_SECONDS=300
DELIVERY_RETRY_ATTEMPTS=2
DELIVERY_COOLDOWN_SECONDS=1
TELEGRAM_INIT_DATA_TTL_SECONDS=3600

# Optional Mini App / web runtime
# Keep WEBAPP_URL empty and WEBAPP_ENABLED=0 for bot-only production.
WEBAPP_URL=
WEBAPP_ENABLED=0
WEBAPP_LISTEN_HOST=127.0.0.1
WEBAPP_LISTEN_PORT=8080
